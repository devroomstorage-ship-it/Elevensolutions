NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eleven_solutions
JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REQUIRE_2FA=false
TOTP_ISSUER=ElevenSolutions
CORS_ORIGINS=http://localhost:3000
PUBLIC_SITE_URL=http://localhost:3000
PORTAL_URL=http://localhost:3000/portal
SENDGRID_API_KEY=REPLACE_ME
EMAIL_FROM=noreply@elevensolutions.co.ke
EMAIL_FROM_NAME=Eleven Solutions Limited
GOOGLE_MAPS_SERVER_KEY=
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:4000/api/quickbooks/callback
QB_SANDBOX=true
# Email transport
# Local Gmail testing: EMAIL_TRANSPORT=smtp
# Render production: EMAIL_TRANSPORT=mailtrap
EMAIL_TRANSPORT=smtp

# Mailtrap production API, used when EMAIL_TRANSPORT=mailtrap
MAILTRAP_API_KEY=

# Gmail local SMTP testing, used when EMAIL_TRANSPORT=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your-16-character-gmail-app-password
EMAIL_FROM=yourgmail@gmail.com
EMAIL_FROM_NAME=Eleven Solutions Limited
